{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "wordcloud-tower",
      "runtimeExecutable": "C:/PROGRA~1/nodejs/node.exe",
      "runtimeArgs": ["-e", "require('http').createServer((req,res)=>{const fs=require('fs'),path=require('path');let f=path.join('E:/wordcloud-tower',req.url==='/'?'/index.html':req.url);fs.readFile(f,(e,d)=>{if(e){res.writeHead(404);res.end('Not found')}else{const ext=path.extname(f);const mime={'html':'text/html','js':'application/javascript','css':'text/css','json':'application/json'};res.writeHead(200,{'Content-Type':mime[ext.slice(1)]||'text/plain'});res.end(d)}})}).listen(3333,()=>console.log('Listening on http://localhost:3333'))"],
      "port": 3333
    }
  ]
}
